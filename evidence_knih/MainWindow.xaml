<Window x:Class="evidence_knih.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:evidence_knih"
        mc:Ignorable="d"
        Title="Evidence knih" 
        Height="480" 
        Width="880"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Datagrid – seznam knih -->
        <DataGrid x:Name="BooksDataGrid"
                  Grid.Column="0"
                  Margin="0,0,12,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AlternatingRowBackground="#F5F7FA"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Název"    Binding="{Binding Title}"    Width="*"     MinWidth="160"/>
                <DataGridTextColumn Header="Kategorie"    Binding="{Binding Author}"   Width="*"     MinWidth="140"/>
                <DataGridTextColumn Header="Obtížnost"     Binding="{Binding Zanr}"     Width="*" MinWidth="70"/>
                <DataGridTextColumn Header="Počet týdnů"      Binding="{Binding RokVydani}" Width="*" MinWidth="40"/>
                <DataGridTextColumn Header=""       Binding="{Binding PocetKusu}" Width="*" MinWidth="30"/>
                <DataGridCheckBoxColumn Header="Zvládnuto" Binding="{Binding Dostupnost}" Width="*" MinWidth="20"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pravý panel – formulář -->
        <Border Grid.Column="1" 
                Background="#F8F9FA" 
                BorderBrush="#D0D7E0" 
                BorderThickness="1" 
                CornerRadius="6"
                Padding="16">

            <StackPanel>

                <TextBlock Text="Knihy" 
                           FontWeight="SemiBold" 
                           FontSize="16" 
                           Margin="0,0,0,16"/>

                <Label Content="Název knihy" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleTextBox" Margin="0,0,0,12" MaxLength="150"/>

                <Label Content="Autor" Margin="0,0,0,4"/>
                <TextBox x:Name="AuthorTextBox" Margin="0,0,0,12" MaxLength="100"/>

                <Label Content="Rok vydání" Margin="0,0,0,4"/>
                <TextBox x:Name="YearTextBox" Margin="0,0,0,12" MaxLength="4"/>

                <Label Content="Žánr" Margin="0,0,0,4"/>
                <TextBox x:Name="GenreTextBox" Margin="0,0,0,12" MaxLength="80"/>

                <Label Content="Počet kusů" Margin="0,0,0,4"/>
                <TextBox x:Name="QuantityTextBox" Margin="0,0,0,20"/>

                <!-- Tlačítka vedle sebe -->
                <UniformGrid Rows="1" HorizontalAlignment="Right" Width="266">
                    <Button x:Name="BtnAdd"    Content="Přidat"    Width="Auto" Margin="0,0,8,0" Click="BtnAdd_Click"/>
                    <Button x:Name="BtnEdit"   Content="Upravit"   Width="Auto" Margin="0,0,8,0" Click="BtnEdit_Click"   IsEnabled="False"/>
                    <Button x:Name="BtnDelete" Content="Smazat"    Width="80
                            " Margin="0,0,8,0" Click="BtnDelete_Click" IsEnabled="False"/>
                </UniformGrid>

            </StackPanel>
        </Border>
    </Grid>
</Window>